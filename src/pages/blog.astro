---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { t } from "../i18n/ui";
import { resolveRoute } from "../i18n/routes";
import { siteConfig } from "../config/site.config";
import { BlogCard } from "../components/blog/index";
import Pagination from "../components/ui/data-display/Pagination/Pagination.astro";

const locale = (Astro.currentLocale || "en") as "en";
const searchParams = Astro.url.searchParams;
const currentTag = searchParams.get("tag") ?? "";
const currentPage = Math.max(1, Number(searchParams.get("page") || "1"));
const slugify = (value: string) =>
  value
    .trim()
    .toLowerCase()
    .replace(/['"]/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const allPosts: CollectionEntry<"blog">[] = await getCollection("blog");
const posts = allPosts
  .filter((p) => p.data.locale === locale && !p.data.draft)
  .sort(
    (a, b) =>
      new Date(b.data.publishDate).getTime() -
      new Date(a.data.publishDate).getTime(),
  );

const filteredPosts = currentTag
  ? posts.filter((post) =>
      (post.data.tags ?? []).some((tag: string) => slugify(tag) === currentTag),
    )
  : posts;
const featuredPost =
  currentPage === 1
    ? (filteredPosts.find((post) => post.data.featured) ?? filteredPosts[0])
    : undefined;
const gridPosts = featuredPost
  ? filteredPosts.filter((post) => post.id !== featuredPost.id)
  : filteredPosts;
const postsPerPage = siteConfig.blog.postsPerPage;
const totalPages = Math.max(1, Math.ceil(gridPosts.length / postsPerPage));
const pagePosts = gridPosts.slice(
  (currentPage - 1) * postsPerPage,
  currentPage * postsPerPage,
);
const allTags = [
  ...new Set(posts.flatMap((post) => post.data.tags || [])),
].sort((a, b) => a.localeCompare(b));
---

<BaseLayout
  title={t(locale, "nav.blog")}
  description={t(locale, "nav.blog")}
  locale={locale}
  path={resolveRoute(locale, "/blog")}
>
  <main class="blog-list container py-12">
    <header class="blog-list__hero">
      <h1>{t(locale, "nav.blog")}</h1>
      <p class="blog-list__lead">
        Articles about web development and the modern stack.
      </p>
      <p class="blog-list__count">
        {filteredPosts.length}
        {filteredPosts.length === 1 ? " article" : " articles"}
        {currentTag && <> tagged <strong>#{currentTag}</strong></>}
      </p>
    </header>

    {
      allTags.length > 0 && (
        <nav class="blog-list__tags" aria-label={t(locale, "blog.filterByTag")}>
          <a
            href={resolveRoute(locale, "/blog")}
            class={`blog-chip${currentTag ? "" : " blog-chip--active"}`}
          >
            All
          </a>
          {allTags.map((tag) => {
            const tagSlug = slugify(tag);
            const active = currentTag === tagSlug;
            const href = active
              ? resolveRoute(locale, "/blog")
              : `${resolveRoute(locale, "/blog")}?tag=${tagSlug}`;
            return (
              <a
                href={href}
                class={`blog-chip${active ? " blog-chip--active" : ""}`}
              >
                {tag}
              </a>
            );
          })}
        </nav>
      )
    }

    {
      filteredPosts.length === 0 && (
        <div class="blog-list__empty">
          <p class="blog-list__empty-title">{t(locale, "blog.noResults")}</p>
          <a class="blog-list__empty-cta" href={resolveRoute(locale, "/blog")}>
            {t(locale, "blog.allPosts")}
          </a>
        </div>
      )
    }

    {
      featuredPost && currentPage === 1 && (
        <section class="blog-list__featured" aria-label="Featured article">
          <BlogCard
            post={featuredPost}
            variant="list"
            locale={locale}
            headingLevel="h2"
          />
        </section>
      )
    }

    {
      pagePosts.length > 0 && (
        <section class="blog-list__grid">
          {pagePosts.map((post) => (
            <BlogCard
              post={post}
              variant="grid"
              locale={locale}
              headingLevel="h2"
            />
          ))}
        </section>
      )
    }

    {
      totalPages > 1 && (
        <Pagination
          currentPage={currentPage}
          totalPages={totalPages}
          basePath={resolveRoute(locale, "/blog")}
          query={currentTag ? { tag: currentTag } : undefined}
          locale={locale}
        />
      )
    }
  </main>
</BaseLayout>

<style>
  .blog-list {
    display: grid;
    gap: var(--space-xl);
  }

  .blog-list__hero {
    max-width: 48rem;
    display: grid;
    gap: var(--space-xs);
  }

  .blog-list__hero h1 {
    margin: 0;
    font-size: clamp(2.25rem, 4vw, 3.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .blog-list__lead {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: 1.0625rem;
    line-height: 1.7;
  }

  .blog-list__count {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: 0.8125rem;
    font-variant-numeric: tabular-nums;
  }

  .blog-list__count strong {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  /* Filter bar */
  .blog-list__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .blog-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.875rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    background: transparent;
    color: var(--color-text-secondary);
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1;
    text-decoration: none;
    transition:
      color 0.15s ease,
      border-color 0.15s ease,
      background 0.15s ease;
  }

  .blog-chip:hover {
    color: var(--color-text-primary);
    border-color: var(--color-text-secondary);
  }

  .blog-chip--active {
    background: var(--color-text-primary);
    border-color: var(--color-text-primary);
    color: var(--color-bg-primary);
  }

  .blog-chip--active:hover {
    color: var(--color-bg-primary);
  }

  /* Empty state */
  .blog-list__empty {
    display: grid;
    justify-items: center;
    gap: var(--space-md);
    padding: var(--space-3xl) var(--space-lg);
    text-align: center;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-2xl);
  }

  .blog-list__empty-title {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: 1.0625rem;
  }

  .blog-list__empty-cta {
    color: var(--color-brand-primary);
    font-weight: 600;
    text-decoration: none;
  }

  .blog-list__empty-cta:hover {
    text-decoration: underline;
  }

  .blog-list__grid {
    display: grid;
    gap: var(--space-lg);
    grid-template-columns: repeat(auto-fill, minmax(19rem, 1fr));
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-chip {
      transition: none;
    }
  }
</style>
