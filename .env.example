# Environment variables
# ---------------------------------------------------------------------------
# Local dev: copy to .env (not committed).
# Production: set these in Cloudflare Pages → Settings → Environment variables.
# Secrets (API tokens) must be set as encrypted secrets in Cloudflare,
# never committed.
#
# Cloudflare bindings (NOT env vars — configure in Pages/wrangler):
#   R2_MEDIA  → R2 bucket (media assets + cleanup worker)

# --- Site -----------------------------------------------------------------
# Public production URL. Falls back to http://localhost:4321 in dev.
# Canonical/OG/sitemap also read src/config/site.config.ts (url).
SITE_URL=

# --- R2 media cleanup worker (functions/api/cleanup.ts) -------------------
# The cleanup endpoint can delete R2 objects, so it requires a bearer secret.
CLEANUP_SECRET=
# CF API token + account ID (optional, for tooling around R2).
CF_ACCOUNT_ID=
CF_API_TOKEN=
# dry-run | quarantine | delete
CLEANUP_MODE=dry-run
CLEANUP_GRACE_DAYS=30

# --- SEO verification (optional) ------------------------------------------
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# --- Contact page map (optional) ------------------------------------------
# The contact page uses a keyless OpenStreetMap embed by default.
# Set lat/lng in src/content/settings.yml.

# --- Analytics & consent (optional, client-side) --------------------------
PUBLIC_GA_MEASUREMENT_ID=
PUBLIC_GTM_ID=
PUBLIC_CONSENT_ENABLED=false
PUBLIC_PRIVACY_POLICY_URL=
